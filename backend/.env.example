# Project Artemis — Backend Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# NEVER commit .env to version control.

# MongoDB connection
MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"

# CORS: comma-separated list of allowed frontend origins.
# Never use * in production — it disables credential isolation.
# Example: CORS_ORIGINS="https://artemis.yourdomain.com,https://app.yourdomain.com"
CORS_ORIGINS="http://localhost:3000"

# UWB proxy shared secret — must match what the UWB verifier expects.
# Generate: openssl rand -hex 32
UWB_SECRET_KEY="REPLACE_WITH_openssl_rand_-hex_32"

# Admin API key for the SIEM dashboard endpoints (/api/security/events, /api/security/summary).
# Generate: openssl rand -hex 32
ARTEMIS_ADMIN_KEY="REPLACE_WITH_openssl_rand_-hex_32"
